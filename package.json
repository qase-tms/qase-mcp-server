{
  "name": "@qase/mcp-server",
  "version": "1.1.6",
  "mcpName": "io.qase/mcp-server",
  "description": "Official MCP server for Qase Test Management Platform",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "qase-mcp-server": "build/index.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qase-tms/qase-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "qase",
    "testing",
    "test-management",
    "model-context-protocol",
    "test-automation",
    "qa",
    "quality-assurance",
    "test-cases",
    "test-runs",
    "defect-tracking",
    "claude",
    "ai-assistant",
    "llm",
    "anthropic"
  ],
  "author": {
    "name": "Qase",
    "email": "support@qase.io",
    "url": "https://qase.io"
  },
  "homepage": "https://github.com/qase-tms/qase-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/qase-tms/qase-mcp-server/issues",
    "email": "support@qase.io"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prebuild": "node -e \"const v=require('./package.json').version; require('fs').writeFileSync('src/version.ts','// Auto-generated by prebuild script — do not edit manually\\nexport const VERSION = \\'' + v + '\\';\\n')\"",
    "build": "tsc && chmod +x build/index.js",
    "prepare": "husky || true",
    "watch": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "pretest": "npm run prebuild",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js",
    "start": "node build/index.js",
    "start:stdio": "node build/index.js --transport stdio",
    "start:sse": "node build/index.js --transport sse --port 3000",
    "start:http": "node build/index.js --transport streamable-http --port 3000"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.13.5",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "neverthrow": "^8.2.0",
    "qase-api-client": "^1.1.7",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.3",
    "prettier": "^3.4.2",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "js-yaml@3": "3.14.2"
  }
}
